# ── QGen Backend — Local Environment ────────────────────────────────────────
# Copy this to .env and fill in the values.

# OpenAI API key (required for schema + dataset generation)
OPENAI_API_KEY=your_openai_api_key_here

# Local data directory (SQLite DB + uploaded files)
# Defaults to ./data  — change if you want to store data elsewhere
QGEN_DATA_DIR=./data

# Qdrant vector store URL (optional — only needed for RAG/enhanced processing)
# Run with:  docker compose up qdrant
QDRANT_URL=http://localhost:6333

# Enhanced processing (RAG context + evolution) — disabled by default
ENABLE_ENHANCED_PROCESSING=false
EVOLUTION_DEPTH=1

# Log level
LOG_LEVEL=INFO
